# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Choose provider: "openrouter" (FREE MODELS) or "openai"
LLM_PROVIDER=openrouter

# OpenRouter Configuration (Free Models)
# Get your free API key from: https://openrouter.io
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary Model - Choose one:
# openai/gpt-oss-120b:free
# deepseek/deepseek-chat-v3-0324:free
# qwen/qwen3-235b-a22b:free
# deepseek/deepseek-r1:free
# meta-llama/llama-4-maverick:free
# nvidia/nemotron-3-super:free
# nvidia/nemotron-3-ultra:free
# google/gemma-3-27b-it:free
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Fallback Models (comma-separated) - Used if primary model is unavailable
OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-chat-v3-0324:free,qwen/qwen3-235b-a22b:free,deepseek/deepseek-r1:free,meta-llama/llama-4-maverick:free,nvidia/nemotron-3-super:free,nvidia/nemotron-3-ultra:free,google/gemma-3-27b-it:free

# OpenAI Configuration (Optional - only if using "openai" provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Embedding Model Configuration
# ============================================================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai

# ============================================================================
# Website Configuration
# ============================================================================
COLLEGE_WEBSITE_URL=https://example.com
CRAWL_DEPTH=5
MAX_PAGES=1000
REQUEST_TIMEOUT=30

# ============================================================================
# ChromaDB Configuration
# ============================================================================
CHROMA_DB_PATH=./vectorstore/chroma_db
PERSIST_DIRECTORY=./knowledge_base

# ============================================================================
# Application Configuration
# ============================================================================
LOG_LEVEL=INFO
DEBUG=False
ENVIRONMENT=production

# ============================================================================
# Document Processing Configuration
# ============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================================================
# Retrieval Configuration
# ============================================================================
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# ============================================================================
# RAGAS Evaluation Configuration
# ============================================================================
RAGAS_BATCH_SIZE=10
RAGAS_TIMEOUT=60

# ============================================================================
# Caching Configuration
# ============================================================================
CACHE_ENABLED=True
CACHE_EMBEDDING_MAX_SIZE=500
CACHE_EMBEDDING_TTL=600
CACHE_LLM_MAX_SIZE=200
CACHE_LLM_TTL=3600
CACHE_CRAWL_MAX_SIZE=100
CACHE_CRAWL_TTL=1800
CACHE_FILE_MAX_SIZE=1000
CACHE_FILE_TTL=300
CACHE_MAX_MEMORY_MB=200

# ============================================================================
# Parallel Execution Configuration
# ============================================================================
PARALLEL_EMBEDDING_WORKERS=4
PARALLEL_CRAWL_WORKERS=8
PARALLEL_GENERAL_WORKERS=4
EMBEDDING_RATE_LIMIT=50
CRAWL_RATE_LIMIT=30

# ============================================================================
# Batch Processing Configuration
# ============================================================================
BATCH_SIZE=50
BATCH_MAX_CONCURRENT=4
BATCH_TIMEOUT=30

# ============================================================================
# Retry Configuration
# ============================================================================
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0

# ============================================================================
# Memory Management
# ============================================================================
MEMORY_MAX_MB=500.0
MEMORY_WARNING_PCT=80.0
MEMORY_CRITICAL_PCT=95.0

# ============================================================================
# Health Check Configuration
# ============================================================================
HEALTH_CHECK_INTERVAL=30

# ============================================================================
# Shutdown Configuration
# ============================================================================
SHUTDOWN_TIMEOUT=30

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_JSON_OUTPUT=False
